#!/usr/bin/env bash
# display-info — show display/session environment at a glance

# ── colours & styles ──────────────────────────────────────────────────────────
BOLD='\033[1m'
DIM='\033[2m'
RST='\033[0m'
C_HEAD='\033[1;36m'   # cyan bold    – section headers
C_KEY='\033[0;33m'    # yellow       – labels
C_VAL='\033[0;97m'    # bright white – values
C_OK='\033[0;32m'     # green        – good/present
C_WARN='\033[0;31m'   # red          – missing/unknown
C_DIM='\033[2;37m'    # dim grey     – secondary info

# ── helpers ───────────────────────────────────────────────────────────────────
WIDTH=62

hr() { printf "${DIM}%${WIDTH}s${RST}\n" | tr ' ' '─'; }

header() {
    echo
    hr
    printf "  ${C_HEAD}%-${WIDTH}s${RST}\n" "$1"
    hr
}

row() {                          # row "Label" "value" ["extra dim text"]
    local key="$1" val="$2" extra="${3:-}"
    if [[ -z "$val" || "$val" == "unknown" || "$val" == "not found" ]]; then
        printf "  ${C_KEY}%-28s${RST}${C_WARN}%s${RST}\n" "$key" "${val:-not found}"
    else
        printf "  ${C_KEY}%-28s${RST}${C_VAL}%s${RST}" "$key" "$val"
        [[ -n "$extra" ]] && printf "  ${C_DIM}%s${RST}" "$extra"
        echo
    fi
}

cmd_or() { command -v "$1" &>/dev/null && "$@" 2>/dev/null || echo ""; }

# ── title ─────────────────────────────────────────────────────────────────────
echo
printf "${C_HEAD}${BOLD}%*s${RST}\n" $(( (WIDTH + 20) / 2 )) "▐ display-info ▌"
echo

# ── 1. desktop / session environment ─────────────────────────────────────────
header "Desktop Environment & Session"

# DE detection: env vars first, then running processes
detect_de() {
    local de="${XDG_CURRENT_DESKTOP:-${DESKTOP_SESSION:-}}"
    if [[ -n "$de" ]]; then
        echo "$de"
        return
    fi
    for proc in gnome-shell plasmashell xfce4-session lxsession lxqt-session \
                mate-session cinnamon-session budgie-panel pantheon-files \
                enlightenment dde-desktop; do
        if pgrep -x "$proc" &>/dev/null; then
            case "$proc" in
                gnome-shell)       echo "GNOME" ;;
                plasmashell)       echo "KDE Plasma" ;;
                xfce4-session)     echo "XFCE" ;;
                lxsession)         echo "LXDE" ;;
                lxqt-session)      echo "LXQt" ;;
                mate-session)      echo "MATE" ;;
                cinnamon-session)  echo "Cinnamon" ;;
                budgie-panel)      echo "Budgie" ;;
                pantheon-files)    echo "Pantheon (Elementary)" ;;
                enlightenment)     echo "Enlightenment" ;;
                dde-desktop)       echo "Deepin DDE" ;;
            esac
            return
        fi
    done
    echo "unknown"
}

DE=$(detect_de)
row "Desktop environment" "$DE"
row "XDG_CURRENT_DESKTOP" "${XDG_CURRENT_DESKTOP:-not set}"
row "DESKTOP_SESSION" "${DESKTOP_SESSION:-not set}"
row "XDG_SESSION_TYPE" "${XDG_SESSION_TYPE:-not set}"
row "XDG_SESSION_CLASS" "${XDG_SESSION_CLASS:-not set}"

# ── 2. display manager ────────────────────────────────────────────────────────
header "Display Manager"

# /etc/X11/default-display-manager
if [[ -r /etc/X11/default-display-manager ]]; then
    DM_PATH=$(cat /etc/X11/default-display-manager)
    DM_NAME=$(basename "$DM_PATH")
    row "/etc/X11/default-display-manager" "$DM_NAME" "($DM_PATH)"
else
    row "/etc/X11/default-display-manager" "not found / unreadable"
fi

# systemd default display-manager service symlink
if [[ -L /etc/systemd/system/display-manager.service ]]; then
    DM_SVC=$(basename "$(readlink /etc/systemd/system/display-manager.service)" .service)
    row "systemd display-manager.service" "$DM_SVC"
else
    row "systemd display-manager.service" "not found"
fi

# running DM process
detect_dm_process() {
    for dm in gdm gdm3 lightdm sddm lxdm xdm slim nodm greetd wdm; do
        if pgrep -x "$dm" &>/dev/null || pgrep -x "${dm}d" &>/dev/null; then
            echo "$dm"; return
        fi
    done
    echo ""
}
DM_PROC=$(detect_dm_process)
row "Running DM process" "${DM_PROC:-not detected}"

# ── 3. loginctl session info ──────────────────────────────────────────────────
header "loginctl Session Info"

if command -v loginctl &>/dev/null; then
    SESSION_ID=$(loginctl show-user "$USER" --property=Sessions --value 2>/dev/null \
                 | tr ' ' '\n' | head -1)
    if [[ -n "$SESSION_ID" ]]; then
        row "Session ID" "$SESSION_ID"
        while IFS='=' read -r k v; do
            v="${v//\"/}"
            case "$k" in
                Type)    row "  Type" "$v" ;;
                Class)   row "  Class" "$v" ;;
                State)   row "  State" "$v" ;;
                Seat)    row "  Seat" "$v" ;;
                TTY)     row "  TTY" "$v" ;;
                Display) row "  Display" "$v" ;;
                Remote)  row "  Remote" "$v" ;;
                Service) row "  Service" "$v" ;;
            esac
        done < <(loginctl show-session "$SESSION_ID" 2>/dev/null)
    else
        # Try listing all sessions for this user
        printf "  ${C_DIM}Sessions for ${USER}:${RST}\n"
        loginctl list-sessions 2>/dev/null \
            | awk -v u="$USER" 'NR==1 || $4==u' \
            | sed 's/^/  /'
    fi
else
    row "loginctl" "not available"
fi

# ── 4. display server & variables ────────────────────────────────────────────
header "Display Server"

row "DISPLAY" "${DISPLAY:-not set}"
row "WAYLAND_DISPLAY" "${WAYLAND_DISPLAY:-not set}"

# X server version
if [[ -n "$DISPLAY" ]] && command -v xdpyinfo &>/dev/null; then
    XVER=$(xdpyinfo 2>/dev/null | awk '/^X.org version:/{print $NF; exit}
                                        /^X11 protocol version/{print "protocol",$NF; exit}')
    row "X server info" "${XVER:-running (xdpyinfo found)}"
elif [[ -n "$WAYLAND_DISPLAY" ]]; then
    # compositor info via wayland
    if command -v weston-info &>/dev/null; then
        WCOMP=$(weston-info 2>/dev/null | awk '/compositor/{print;exit}')
        row "Wayland compositor info" "${WCOMP:-wayland active}"
    else
        row "Wayland compositor" "active (weston-info not installed)"
    fi
fi

# Compositor process
for comp in kwin_wayland kwin_x11 mutter muffin xfwm4 openbox i3 sway \
            hyprland river wayfire labwc picom compton; do
    if pgrep -x "$comp" &>/dev/null; then
        row "Window manager/compositor" "$comp"
        break
    fi
done

# ── 5. screen resolution & monitors ──────────────────────────────────────────
header "Screen / Resolution"

if [[ -n "$DISPLAY" ]] && command -v xrandr &>/dev/null; then
    # Primary resolution — use geometry from the "connected" line (e.g. 1920x1080+0+0)
    PRIMARY=$(xrandr --current 2>/dev/null \
              | awk '/connected primary/{for(i=1;i<=NF;i++) if($i~/^[0-9]+x[0-9]+\+/) {split($i,a,"+"); print a[1]; exit}}')
    [[ -z "$PRIMARY" ]] && PRIMARY=$(xrandr --current 2>/dev/null \
              | awk '/ connected /{for(i=1;i<=NF;i++) if($i~/^[0-9]+x[0-9]+\+/) {split($i,a,"+"); print a[1]; exit}}')
    row "Primary resolution" "${PRIMARY:-unknown}"

    # All connected outputs
    echo
    printf "  ${C_DIM}Connected outputs:${RST}\n"
    xrandr --current 2>/dev/null | awk '
        / connected/ {
            out = $1
            res = "off"
            for (i=1;i<=NF;i++) if ($i ~ /^[0-9]+x[0-9]+\+/) { split($i,a,"+"); res=a[1]"@+"a[2]","a[3] }
            printf "  %-18s  %s\n", out, res
        }'

    # DPI
    DPI=$(xdpyinfo 2>/dev/null | awk '/resolution/{print $2; exit}')
    [[ -n "$DPI" ]] && row "DPI" "$DPI"

elif command -v wlr-randr &>/dev/null; then
    echo
    printf "  ${C_DIM}Wayland outputs (wlr-randr):${RST}\n"
    wlr-randr 2>/dev/null | grep -E '^\S|  \S' | sed 's/^/  /'

elif command -v kscreen-doctor &>/dev/null; then
    echo
    printf "  ${C_DIM}Wayland outputs (kscreen-doctor):${RST}\n"
    kscreen-doctor -o 2>/dev/null | grep -E 'Output|Resolution|enabled' | sed 's/^/  /'

elif [[ -r /sys/class/drm ]]; then
    echo
    printf "  ${C_DIM}DRM outputs (/sys/class/drm):${RST}\n"
    for conn in /sys/class/drm/card*-*; do
        name=$(basename "$conn")
        status=$(cat "$conn/status" 2>/dev/null)
        modes=$(head -1 "$conn/modes" 2>/dev/null)
        printf "  %-22s  %-14s  %s\n" "$name" "${status:-?}" "${modes:-}"
    done
fi

# ── 6. GPU / Mesa capabilities ────────────────────────────────────────────────
header "Graphics Hardware & Mesa Capabilities"

# lspci GPU entries
if command -v lspci &>/dev/null; then
    GPU_LINES=$(lspci 2>/dev/null | grep -iE 'vga|3d controller|display controller|gpu')
    if [[ -n "$GPU_LINES" ]]; then
        printf "  ${C_DIM}PCI display devices:${RST}\n"
        while IFS= read -r line; do
            printf "  %s\n" "$line"
        done <<< "$GPU_LINES"
        echo
    fi
fi

if command -v glxinfo &>/dev/null && [[ -n "$DISPLAY" ]]; then
    # Run once and cache
    GLX=$( glxinfo -B 2>/dev/null )
    GLX_FULL=$( glxinfo    2>/dev/null )

    # ── identity ──────────────────────────────────────────────────────────────
    GL_VENDOR=$(   awk '/^OpenGL vendor string:/{   print substr($0,index($0,$4)) }' <<< "$GLX_FULL" | head -1)
    GL_RENDERER=$( awk '/^OpenGL renderer string:/{  print substr($0,index($0,$4)) }' <<< "$GLX_FULL" | head -1)
    MESA_VER=$(    awk '/^OpenGL version string:/{   match($0,/Mesa [0-9.]+/); print substr($0,RSTART,RLENGTH) }' <<< "$GLX_FULL" | head -1)
    MESA_DRIVER=$( awk '/Device:/{                   print substr($0,index($0,$2)) }' <<< "$GLX" | head -1)

    row "GL vendor" "${GL_VENDOR:-unknown}"
    row "GL renderer" "${GL_RENDERER:-unknown}"
    row "Mesa version" "${MESA_VER:-unknown}"

    # Hardware-accelerated?  (Accelerated: field from MESA query_renderer)
    HW_ACCEL=$( awk '/^    Accelerated:/{print $2}' <<< "$GLX" | head -1 )
    DR=$(        awk '/^direct rendering:/{print $3}' <<< "$GLX_FULL" | head -1 )
    if [[ "$HW_ACCEL" == "yes" ]]; then
        printf "  ${C_KEY}%-28s${RST}${C_OK}%s${RST}\n" "Hardware accelerated" "yes  (direct rendering: ${DR:-?})"
    else
        printf "  ${C_KEY}%-28s${RST}${C_WARN}%s${RST}\n" "Hardware accelerated" "no (software/llvmpipe)  direct rendering: ${DR:-?}"
    fi

    # ── profile versions ──────────────────────────────────────────────────────
    echo
    printf "  ${C_DIM}OpenGL profile versions:${RST}\n"

    # Each line ends with the value after "string: " — split on ": " and take the rest
    GL_CORE=$(  awk '/^OpenGL core profile version string:/{  sub(/.*string: /,""); print }' <<< "$GLX_FULL" | head -1)
    GL_COMPAT=$( awk '/^OpenGL version string:/{               sub(/.*string: /,""); print }' <<< "$GLX_FULL" | head -1)
    GL_ES=$(    awk '/^OpenGL ES profile version string:/{    sub(/.*string: /,""); print }' <<< "$GLX_FULL" | head -1)
    GLSL=$(     awk '/^OpenGL shading language version string:/{sub(/.*string: /,""); print }' <<< "$GLX_FULL" | head -1)
    GLSL_ES=$(  awk '/^OpenGL ES profile shading language/{   sub(/.*string: /,""); print }' <<< "$GLX_FULL" | head -1)
    GLX_VER=$(  awk '/^GLX version:/{                         print $3 }' <<< "$GLX_FULL" | head -1)

    printf "  ${C_KEY}%-28s${RST}${C_VAL}%s${RST}\n" "  Core profile"    "${GL_CORE:-unknown}"
    printf "  ${C_KEY}%-28s${RST}${C_VAL}%s${RST}\n" "  Compat profile"  "${GL_COMPAT:-unknown}"
    printf "  ${C_KEY}%-28s${RST}${C_VAL}%s${RST}\n" "  OpenGL ES"       "${GL_ES:-unknown}"
    printf "  ${C_KEY}%-28s${RST}${C_VAL}%s${RST}\n" "  GLSL version"    "${GLSL:-unknown}"
    printf "  ${C_KEY}%-28s${RST}${C_VAL}%s${RST}\n" "  GLSL ES version" "${GLSL_ES:-unknown}"
    printf "  ${C_KEY}%-28s${RST}${C_VAL}%s${RST}\n" "  GLX version"     "${GLX_VER:-unknown}"

    # ── Mesa query_renderer caps ──────────────────────────────────────────────
    echo
    printf "  ${C_DIM}Mesa GLX_MESA_query_renderer:${RST}\n"

    MQR_VENDOR=$(  awk '/^    Vendor:/{           print substr($0,index($0,$2)) }' <<< "$GLX" | head -1)
    MQR_DEVICE=$(  awk '/^    Device:/{           print substr($0,index($0,$2)) }' <<< "$GLX" | head -1)
    MQR_VER=$(     awk '/^    Version:/{          print $2 }' <<< "$GLX" | head -1)
    MQR_VRAM=$(    awk '/^    Video memory:/{     print $3,$4 }' <<< "$GLX" | head -1)
    MQR_UNIFIED=$( awk '/^    Unified memory:/{   print $3 }' <<< "$GLX" | head -1)
    MQR_PROFILE=$( awk '/^    Preferred profile:/{print $3,$4 }' <<< "$GLX" | head -1)
    MQR_MAXCORE=$( awk '/^    Max core profile version:/{  print $5 }' <<< "$GLX" | head -1)
    MQR_MAXCOMPAT=$(awk '/^    Max compat profile version:/{print $5 }' <<< "$GLX" | head -1)
    MQR_MAXES1=$(  awk '/^    Max GLES1 profile version:/{  print $5 }' <<< "$GLX" | head -1)
    MQR_MAXES23=$( awk '/^    Max GLES\[23\] profile version:/{print $5 }' <<< "$GLX" | head -1)

    printf "  ${C_KEY}%-28s${RST}${C_VAL}%s${RST}\n" "  Vendor"                "${MQR_VENDOR:-unknown}"
    printf "  ${C_KEY}%-28s${RST}${C_VAL}%s${RST}\n" "  Device"                "${MQR_DEVICE:-unknown}"
    printf "  ${C_KEY}%-28s${RST}${C_VAL}%s${RST}\n" "  Mesa version"          "${MQR_VER:-unknown}"
    printf "  ${C_KEY}%-28s${RST}${C_VAL}%s${RST}\n" "  Video memory"          "${MQR_VRAM:-unknown}"
    printf "  ${C_KEY}%-28s${RST}${C_VAL}%s${RST}\n" "  Unified memory"        "${MQR_UNIFIED:-unknown}"
    printf "  ${C_KEY}%-28s${RST}${C_VAL}%s${RST}\n" "  Preferred profile"     "${MQR_PROFILE:-unknown}"
    printf "  ${C_KEY}%-28s${RST}${C_VAL}%s${RST}\n" "  Max core GL"           "${MQR_MAXCORE:-unknown}"
    printf "  ${C_KEY}%-28s${RST}${C_VAL}%s${RST}\n" "  Max compat GL"         "${MQR_MAXCOMPAT:-unknown}"
    printf "  ${C_KEY}%-28s${RST}${C_VAL}%s${RST}\n" "  Max GLES 1"            "${MQR_MAXES1:-unknown}"
    printf "  ${C_KEY}%-28s${RST}${C_VAL}%s${RST}\n" "  Max GLES 2/3"          "${MQR_MAXES23:-unknown}"

    # ── memory (ATI/NV info blocks) ───────────────────────────────────────────
    ATI_MEM=$(awk '/Memory info \(GL_ATI_meminfo\)/{found=1} found && /aux\. memory - total/{print; found=0}' <<< "$GLX" | head -1)
    NV_TOTAL=$( awk '/Total available memory:/{print $4,$5}' <<< "$GLX" | head -1)
    NV_AVAIL=$(  awk '/Currently available dedicated/{print $6,$7}' <<< "$GLX" | head -1)
    if [[ -n "$NV_TOTAL" ]]; then
        echo
        printf "  ${C_DIM}Video memory (GL_NVX_gpu_memory_info):${RST}\n"
        printf "  ${C_KEY}%-28s${RST}${C_VAL}%s${RST}\n" "  Total available"   "${NV_TOTAL}"
        printf "  ${C_KEY}%-28s${RST}${C_VAL}%s${RST}\n" "  Currently avail."  "${NV_AVAIL:-unknown}"
    fi

    # ── extension count ───────────────────────────────────────────────────────
    EXT_COUNT=$(grep -c 'GL_' <<< "$GLX_FULL" 2>/dev/null || echo 0)
    GLX_EXT_COUNT=$(awk '/^    GLX_/{c++} END{print c+0}' <<< "$GLX_FULL")
    echo
    printf "  ${C_KEY}%-28s${RST}${C_VAL}%s${RST}\n" "GL extensions total"  "${EXT_COUNT}"
    printf "  ${C_KEY}%-28s${RST}${C_VAL}%s${RST}\n" "GLX extensions"       "${GLX_EXT_COUNT}"

    # ── notable capability flags ──────────────────────────────────────────────
    echo
    printf "  ${C_DIM}Notable capabilities (from GL extensions):${RST}\n"
    declare -A CAPS=(
        ["Geometry shaders"]="GL_ARB_geometry_shader4\|GL_EXT_geometry_shader"
        ["Tessellation"]="GL_ARB_tessellation_shader"
        ["Compute shaders"]="GL_ARB_compute_shader"
        ["Multi-draw indirect"]="GL_ARB_multi_draw_indirect"
        ["Shader storage (SSBO)"]="GL_ARB_shader_storage_buffer_object"
        ["Bindless textures"]="GL_ARB_bindless_texture"
        ["Sparse textures"]="GL_ARB_sparse_texture"
        ["64-bit float (FP64)"]="GL_ARB_gpu_shader_fp64"
        ["Half-float vertex"]="GL_ARB_half_float_vertex"
        ["sRGB framebuffer"]="GL_ARB_framebuffer_sRGB\|GL_EXT_framebuffer_sRGB"
        ["Multisample (MSAA)"]="GL_ARB_multisample"
        ["Anisotropic filter"]="GL_EXT_texture_filter_anisotropic\|GL_ARB_texture_filter_anisotropic"
        ["Debug output"]="GL_ARB_debug_output\|GL_KHR_debug"
        ["Sync objects"]="GL_ARB_sync"
        ["Timer queries"]="GL_ARB_timer_query\|GL_EXT_timer_query"
        ["Transform feedback"]="GL_ARB_transform_feedback2"
        ["Instanced drawing"]="GL_ARB_instanced_arrays\|GL_ARB_draw_instanced"
        ["Conditional render"]="GL_NV_conditional_render\|GL_ARB_conditional_render_inverted"
        ["Occlusion queries"]="GL_ARB_occlusion_query"
        ["Direct state access"]="GL_ARB_direct_state_access"
    )
    # Sort keys for consistent order
    for cap in \
        "Geometry shaders" "Tessellation" "Compute shaders" \
        "Shader storage (SSBO)" "64-bit float (FP64)" "Half-float vertex" \
        "Bindless textures" "Sparse textures" "Multi-draw indirect" \
        "Instanced drawing" "Transform feedback" "Conditional render" \
        "Occlusion queries" "Timer queries" "Anisotropic filter" \
        "sRGB framebuffer" "Multisample (MSAA)" "Sync objects" \
        "Debug output" "Direct state access"; do
        pat="${CAPS[$cap]}"
        if grep -qE "$pat" <<< "$GLX_FULL"; then
            printf "  ${C_OK}  ✔  ${RST}${C_VAL}%s${RST}\n" "$cap"
        else
            printf "  ${C_DIM}  ✘  %s${RST}\n" "$cap"
        fi
    done

elif command -v glxinfo &>/dev/null; then
    row "glxinfo" "available but DISPLAY not set"
fi

# nvidia-smi if present
if command -v nvidia-smi &>/dev/null; then
    echo
    printf "  ${C_DIM}NVIDIA (nvidia-smi):${RST}\n"
    nvidia-smi --query-gpu=name,driver_version,memory.total,temperature.gpu,utilization.gpu \
               --format=csv,noheader 2>/dev/null \
    | while IFS=',' read -r name drv mem temp util; do
        printf "  %-30s  driver %-10s  mem %-8s  %s°C  gpu %s\n" \
               "${name# }" "${drv# }" "${mem# }" "${temp# }" "${util# }"
    done
fi

# Vulkan info summary
if command -v vulkaninfo &>/dev/null; then
    echo
    printf "  ${C_DIM}Vulkan:${RST}\n"
    vulkaninfo --summary 2>/dev/null | grep -E 'GPU|driverVersion|apiVersion|deviceType' \
    | sed 's/^[[:space:]]*/  /' | head -12
fi

# VA-API (video acceleration)
if command -v vainfo &>/dev/null; then
    echo
    printf "  ${C_DIM}VA-API (video acceleration):${RST}\n"
    VAINFO=$(vainfo 2>/dev/null)
    VA_DRIVER=$(awk '/VA-API version|Driver version|vainfo:/{print; exit}' <<< "$VAINFO")
    VA_PROFILES=$(grep -c 'VAProfile' <<< "$VAINFO" 2>/dev/null || echo 0)
    [[ -n "$VA_DRIVER"   ]] && printf "  %s\n" "$VA_DRIVER"
    [[ "$VA_PROFILES" -gt 0 ]] && printf "  ${C_KEY}%-28s${RST}${C_VAL}%s${RST}\n" "  Supported profiles" "$VA_PROFILES"
fi

# VDPAU
if command -v vdpauinfo &>/dev/null; then
    echo
    printf "  ${C_DIM}VDPAU:${RST}\n"
    vdpauinfo 2>/dev/null | grep -E 'VDPAU|implementation|version' | head -4 | sed 's/^/  /'
fi

# ── 7. misc useful vars ────────────────────────────────────────────────────────
header "Miscellaneous"

row "USER / UID" "${USER} / $(id -u)"
row "Hostname" "$(hostname 2>/dev/null)"
row "Kernel" "$(uname -r 2>/dev/null)"
row "LANG / locale" "${LANG:-not set}"
row "DBUS_SESSION_BUS_ADDRESS" "${DBUS_SESSION_BUS_ADDRESS:+set ($(echo "$DBUS_SESSION_BUS_ADDRESS" | cut -c1-30)…)}"
[[ -z "$DBUS_SESSION_BUS_ADDRESS" ]] && row "DBUS_SESSION_BUS_ADDRESS" "not set"

# uptime
UP=$(uptime -p 2>/dev/null)
row "Uptime" "${UP:-$(uptime 2>/dev/null)}"

echo
hr
echo
